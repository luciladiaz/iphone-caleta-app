# ── Firebase (cliente) ────────────────────────────────────────────────────────
# Obtené los valores en: Firebase Console → Configuración del proyecto → SDK
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ── Firebase Admin (servidor) ─────────────────────────────────────────────────
# Para el webhook que actualiza Firestore. Obtené en:
# Firebase Console → Configuración del proyecto → Cuentas de servicio → Generar nueva clave privada
# Pegá todo el contenido del JSON como una sola línea (sin saltos de línea)
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"..."}

# ── MercadoPago ───────────────────────────────────────────────────────────────
# Obtené en: mercadopago.com.ar → Desarrolladores → Credenciales de producción
MP_ACCESS_TOKEN=APP_USR-...

# ── App ───────────────────────────────────────────────────────────────────────
# URL de tu app en producción (sin barra final)
APP_URL=https://iphone-caleta-app.vercel.app
